{
  "name": "@saphnexa/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "ui-docs:generate": "tsx tools/ui-docs/cli.ts generate",
    "ui-docs:check": "tsx tools/ui-docs/cli.ts generate --check",
    "ui-archlint": "tsx tools/ui-docs/cli.ts lint",
    "test": "nuxt prepare && vitest run",
    "test:watch": "nuxt prepare && vitest",
    "test:coverage": "nuxt prepare && vitest run --coverage"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@nuxt/ui": "^4.9.0",
    "nuxt": "^4.4.5",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.0",
    "vue-router": "^4.6.0"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.1.5"
  }
}
